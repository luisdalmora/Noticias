---
import '../styles/global.css';
import Sidebar from '../components/layout/Sidebar.astro';
import Topbar from '../components/layout/Topbar.astro';
import MobileNav from '../components/layout/MobileNav.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="bg-[#050505] text-white overflow-x-hidden">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Noticias Premium - OS Dashboard" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Noticias Premium</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen flex">
		<Sidebar />
		
		<main class="flex-1 flex flex-col min-w-0">
			<Topbar />
			
			<div class="p-6 lg:p-10 max-w-7xl mx-auto w-full pb-32 lg:pb-10">
				<slot />
			</div>

			<MobileNav />
		</main>

		<script>
			// Client-side initialization
			console.log('🎮 Noticias Premium OS Initialized');
		</script>
	</body>
</html>
