---
const items = [
  { href: '/', icon: '🏠', label: 'Home' },
  { href: '/nintendo', icon: '🎮', label: 'Nin' },
  { href: '/samsung', icon: '📱', label: 'Sam' },
  { href: '/rumores', icon: '🕵️', label: 'Rum' },
  { href: '/historico', icon: '📚', label: 'Hist' },
];

const currentPath = Astro.url.pathname;
---

<nav class="lg:hidden fixed bottom-6 left-6 right-6 z-[100] glass-panel flex items-center justify-between px-6 py-4 shadow-2xl">
  {items.map(item => (
    <a 
      href={item.href} 
      class={`flex flex-col items-center gap-1 transition-all ${
        currentPath === item.href ? 'text-red-500 scale-110' : 'text-gray-500 hover:text-white'
      }`}
    >
      <span class="text-2xl">{item.icon}</span>
      <span class="text-[8px] font-black uppercase tracking-widest">{item.label}</span>
    </a>
  ))}
</nav>
